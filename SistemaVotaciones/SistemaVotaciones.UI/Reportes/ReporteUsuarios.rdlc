                    <Textbox Name="HeaderPadron">
                      <CanGrow>true</CanGrow>
                      <KeepTogether>true</KeepTogether>
                      <Paragraphs><Paragraph><TextRuns><TextRun><Value>Padrón</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs>
                      <Style><BackgroundColor>LightGray</BackgroundColor><Border><Style>Solid</Style></Border></Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>

                <TablixCell>
                  <CellContents>
                    <Textbox Name="HeaderEstado">
                      <CanGrow>true</CanGrow>
                      <KeepTogether>true</KeepTogether>
                      <Paragraphs><Paragraph><TextRuns><TextRun><Value>Estado</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs>
                      <Style><BackgroundColor>LightGray</BackgroundColor><Border><Style>Solid</Style></Border></Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>

                <TablixCell>
                  <CellContents>
                    <Textbox Name="HeaderYaVoto">
                      <CanGrow>true</CanGrow>
                      <KeepTogether>true</KeepTogether>
                      <Paragraphs><Paragraph><TextRuns><TextRun><Value>Ya votó</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs>
                      <Style><BackgroundColor>LightGray</BackgroundColor><Border><Style>Solid</Style></Border></Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>

              </TablixCells>
            </TablixRow>

            <TablixRow>
              <Height>0.25in</Height>
              <TablixCells>

                <TablixCell>
                  <CellContents>
                    <Textbox Name="TxtMatricula">
                      <CanGrow>true</CanGrow>
                      <KeepTogether>true</KeepTogether>
                      <Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!Matricula.Value</Value><Style /></TextRun></TextRuns></Paragraph></Paragraphs>
                      <Style><Border><Style>Solid</Style></Border></Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>

                <TablixCell>
                  <CellContents>
                    <Textbox Name="TxtNombreCompleto">
                      <CanGrow>true</CanGrow>
                      <KeepTogether>true</KeepTogether>
                      <Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!NombreCompleto.Value</Value><Style /></TextRun></TextRuns></Paragraph></Paragraphs>
                      <Style><Border><Style>Solid</Style></Border></Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>

                <TablixCell>
                  <CellContents>
                    <Textbox Name="TxtUsername">
                      <CanGrow>true</CanGrow>
                      <KeepTogether>true</KeepTogether>
                      <Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!Username.Value</Value><Style /></TextRun></TextRuns></Paragraph></Paragraphs>
                      <Style><Border><Style>Solid</Style></Border></Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>

                <TablixCell>
                  <CellContents>
                    <Textbox Name="TxtRol">
                      <CanGrow>true</CanGrow>
                      <KeepTogether>true</KeepTogether>
                      <Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!NombreRol.Value</Value><Style /></TextRun></TextRuns></Paragraph></Paragraphs>
                      <Style><Border><Style>Solid</Style></Border></Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>

                <TablixCell>
                  <CellContents>
                    <Textbox Name="TxtPadron">
                      <CanGrow>true</CanGrow>
                      <KeepTogether>true</KeepTogether>
                      <Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!NombrePadron.Value</Value><Style /></TextRun></TextRuns></Paragraph></Paragraphs>
                      <Style><Border><Style>Solid</Style></Border></Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>

                <TablixCell>
                  <CellContents>
                    <Textbox Name="TxtEstado">
                      <CanGrow>true</CanGrow>
                      <KeepTogether>true</KeepTogether>
                      <Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!Estado.Value</Value><Style /></TextRun></TextRuns></Paragraph></Paragraphs>
                      <Style><Border><Style>Solid</Style></Border></Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>

                <TablixCell>
                  <CellContents>
                    <Textbox Name="TxtYaVoto">
                      <CanGrow>true</CanGrow>
                      <KeepTogether>true</KeepTogether>
                      <Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!YaVoto.Value</Value><Style /></TextRun></TextRuns></Paragraph></Paragraphs>
                      <Style><Border><Style>Solid</Style></Border></Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>

              </TablixCells>
            </TablixRow>
          </TablixRows>
        </TablixBody>

        <TablixColumnHierarchy>
          <TablixMembers>
            <TablixMember />
            <TablixMember />
            <TablixMember />
            <TablixMember />
            <TablixMember />
            <TablixMember />
            <TablixMember />
          </TablixMembers>
        </TablixColumnHierarchy>

        <TablixRowHierarchy>
          <TablixMembers>
            <TablixMember>
              <KeepWithGroup>After</KeepWithGroup>
              <RepeatOnNewPage>true</RepeatOnNewPage>
            </TablixMember>
            <TablixMember>
              <Group Name="DetalleUsuarios" />
            </TablixMember>
          </TablixMembers>
        </TablixRowHierarchy>

        <DataSetName>DataSetUsuarios</DataSetName>
        <Top>0.75in</Top>
        <Left>0.1in</Left>
        <Height>0.55in</Height>
        <Width>7.3in</Width>
        <Style><Border><Style>None</Style></Border></Style>
      </Tablix>

    </ReportItems>

    <Height>2in</Height>
    <Style />
  </Body>

  <Width>7.6in</Width>

  <Page>
    <PageHeight>11in</PageHeight>
    <PageWidth>8.5in</PageWidth>
    <LeftMargin>0.5in</LeftMargin>
    <RightMargin>0.5in</RightMargin>
    <TopMargin>0.5in</TopMargin>
    <BottomMargin>0.5in</BottomMargin>
    <Style />
  </Page>

  <AutoRefresh>0</AutoRefresh>
  <rd:ReportUnitType>Inch</rd:ReportUnitType>
  <rd:ReportID>55555555-5555-5555-5555-555555555555</rd:ReportID>

</Report>